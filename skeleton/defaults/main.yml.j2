---
#
# Role Control
#

# Enable the {{ role_name }} role
{{ role_name }}_enabled: true

# Enable and start the {{ role_name }} service
{{ role_name }}_service_enabled: true

#
# TODO: Role-Specific Settings
#

# TODO: Add role-specific variables here

#
# Firewall
#

# Enable firewalld integration
{{ role_name }}_firewalld_enabled: false

# Firewalld zone for service rules
{{ role_name }}_firewalld_zone: 'public'

#
# AppArmor
#

# Enable AppArmor profile enforcement (Arch/Debian only, not RHEL/Rocky)
{{ role_name }}_apparmor_enabled: false
