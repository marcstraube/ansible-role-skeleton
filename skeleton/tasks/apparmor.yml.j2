---
# =============================================================================
# {{ role_name }} - AppArmor Tasks
# =============================================================================

- name: AppArmor | Check if AppArmor is active
  ansible.builtin.stat:
    path: /sys/kernel/security/apparmor
  register: __{{ role_name }}_apparmor_active

- name: AppArmor | Get current profile status
  ansible.builtin.command:
    cmd: aa-status --json
  register: __{{ role_name }}_aa_status
  changed_when: false
  failed_when: false
  when: __{{ role_name }}_apparmor_active.stat.exists

- name: AppArmor | Build enforce set
  ansible.builtin.set_fact:
    __{{ role_name }}_apparmor_enforce_set: >-
      {{ '{{' }} (__{{ role_name }}_aa_status.stdout | default('{}') | from_json).get('profiles', {})
         | dict2items | selectattr('value', 'eq', 'enforce')
         | map(attribute='key') | list {{ '}}' }}
  when:
    - __{{ role_name }}_apparmor_active.stat.exists
    - __{{ role_name }}_aa_status.rc == 0

- name: AppArmor | Enforce {{ role_name }} profile
  ansible.builtin.command:
    cmd: 'aa-enforce {{ '{{' }} __{{ role_name }}_apparmor_profile {{ '}}' }}'
  when:
    - __{{ role_name }}_apparmor_active.stat.exists
    - >-
      __{{ role_name }}_apparmor_profile not in __{{ role_name }}_apparmor_enforce_set | default([])
      and (__{{ role_name }}_apparmor_profile | basename) not in __{{ role_name }}_apparmor_enforce_set | default([])
  changed_when: true
