---
- name: Verify
  hosts: all
  gather_facts: true

  tasks:
    #
    # Load OS-Specific Variables
    #

    - name: Verify | Load OS-specific variables
      ansible.builtin.include_vars: '{{ '{{' }} item {{ '}}' }}'
      with_first_found:
        - files:
            - '{{ '{{' }} ansible_facts["distribution"] {{ '}}' }}-{{ '{{' }} ansible_facts["distribution_major_version"] {{ '}}' }}.yml'
            - '{{ '{{' }} ansible_facts["os_family"] {{ '}}' }}-{{ '{{' }} ansible_facts["distribution_major_version"] {{ '}}' }}.yml'
            - '{{ '{{' }} ansible_facts["distribution"] {{ '}}' }}.yml'
            - '{{ '{{' }} ansible_facts["os_family"] {{ '}}' }}.yml'
          paths:
            - '../../vars'

    #
    # Package Verification
    #

    - name: Verify | Check {{ role_name }} package is installed
      ansible.builtin.package:
        name: TODO
        state: present
      check_mode: true
      register: __{{ role_name }}_pkg_check
      failed_when: __{{ role_name }}_pkg_check.changed

    #
    # Service Verification
    #

    - name: Verify | Check {{ role_name }} service is enabled and running
      ansible.builtin.systemd_service:
        name: '{{ '{{' }} __{{ role_name }}_service_name {{ '}}' }}'
      register: __{{ role_name }}_svc_check

    - name: Verify | Assert {{ role_name }} service is active
      ansible.builtin.assert:
        that:
          - __{{ role_name }}_svc_check.status.ActiveState == 'active'
          - __{{ role_name }}_svc_check.status.UnitFileState == 'enabled'
        fail_msg: "{{ role_name }} service is not active or enabled"
        success_msg: "{{ role_name }} service is active and enabled"

    #
    # Configuration Verification
    #

    # TODO: Add role-specific verification tasks
