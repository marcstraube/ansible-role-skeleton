---
- name: Prepare
  hosts: all
  become: true
  gather_facts: true

  tasks:
    - name: Prepare | Full system update (Arch)
      community.general.pacman:
        update_cache: true
        upgrade: true
      when: ansible_facts['os_family'] == 'Archlinux'

    - name: Prepare | Install base packages (Debian)
      ansible.builtin.apt:
        name:
          - systemd
          - procps
        state: present
        update_cache: true
      when: ansible_facts['os_family'] == 'Debian'

    - name: Prepare | Install base packages (RedHat)
      ansible.builtin.dnf:
        name:
          - systemd
          - procps-ng
        state: present
        update_cache: true
      when: ansible_facts['os_family'] == 'RedHat'

    # TODO: Add role-specific preparation tasks
    # (e.g., pre-install packages, systemd service overrides for containers)
